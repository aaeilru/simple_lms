              "raw": "{\n  \"username\": \"mahasiswa01\",\n  \"password\": \"password123\",\n  \"email\": \"mahasiswa01@example.com\",\n  \"first_name\": \"Budi\",\n  \"last_name\": \"Santoso\"\n}"
            }
