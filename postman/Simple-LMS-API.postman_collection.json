        {
          "name": "Login / Sign In",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/sign-in",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "sign-in"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"mahasiswa01\",\n  \"password\": \"password123\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "",
                  "pm.test(\"Login success\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "let jsonData = pm.response.json();",
                  "if (jsonData.access) {",
                  "    pm.collectionVariables.set(\"access_token\", jsonData.access);",
                  "}",
                  "if (jsonData.refresh) {",
                  "    pm.collectionVariables.set(\"refresh_token\", jsonData.refresh);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
